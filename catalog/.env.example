# Database
DATABASE_URL=postgresql://sixpet:sixpet123@postgres:5432/sixpet_catalog

# Redis
REDIS_URL=redis://redis:6379/0

# Groq API Keys (comma separated for rotation)
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Storage Configuration
# Options: filesystem, s3, minio
STORAGE_TYPE=filesystem
STORAGE_PATH=/app/storage

# S3/MinIO Configuration (only if STORAGE_TYPE=s3 or minio)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=sixpet-catalog
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=https://cdn.sixpet.com

# API
API_HOST=0.0.0.0
API_PORT=8000
